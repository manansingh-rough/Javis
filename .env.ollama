# NEXUS AI v4.0 — Ollama Local LLM Configuration
# Date: 2026-07-06
# Hardware: Intel i7-12800H (14 cores) · 64GB RAM · NVIDIA Discrete GPU

# ─── Ollama Backend ──────────────────────────────────────────────────────────
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL_PRIMARY=mistral
OLLAMA_MODEL_SECONDARY=neural-chat
OLLAMA_MODEL_FALLBACK=llama2

# ─── LLM Router Configuration ────────────────────────────────────────────────
LLM_BACKEND=ollama
LLM_ROUTER_MODE=intelligent  # Routes based on task complexity
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ─── Performance Tuning ─────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
OLLAMA_NUM_THREADS=8
OLLAMA_KEEP_ALIVE=5m
CUDA_VISIBLE_DEVICES=0  # Use discrete GPU if available

# ─── Memory Management ──────────────────────────────────────────────────────
MEMORY_COMPRESSION=enabled
MEMORY_MAX_SIZE=50GB
MEMORY_CLEANUP_INTERVAL=3600  # seconds

# ─── Context Window ─────────────────────────────────────────────────────────
CONTEXT_WINDOW_SIZE=4096
CONTEXT_HISTORY_LIMIT=20

# ─── Agent Configuration ────────────────────────────────────────────────────
AGENT_MODE=autonomous
AGENT_TIMEOUT=300
AGENT_RETRY_ATTEMPTS=3

# ─── Groq API (Fallback for heavy workloads) ────────────────────────────────
# Leave empty to use only local Ollama
# GROQ_API_KEY=your_key_here
# GROQ_MODEL=mixtral-8x7b-32768

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/nexus.log
DEBUG_MODE=false
